# Required
FHIR_BASE_URL=https://fhir.example.org
# Derives: FHIR server  → <base>/api/FHIR/R4
#          Token endpoint → <base>/oauth2/token
FHIR_CLIENT_ID=your-client-id

# Path to your PKCS#8 RSA private key PEM file (relative to cwd or absolute)
# Generate with: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private.pem
FHIR_PRIVATE_KEY=./private.pem

# Commonly Required
# Public JWKS URL registered with your FHIR authorization server
# Used to include jku + kid claims in the JWT assertion
FHIR_JWKS_URL=
# kid value from your JWKS — must match exactly or auth will fail
FHIR_KEY_ID=your-key-id

# Optional URL Overrides
# Override the derived FHIR API + token URLs for non-standard server layouts
# When set, these take precedence over values derived from FHIR_BASE_URL
# FHIR_SERVER_URL=https://fhir.example.org/fhir/R4
# FHIR_TOKEN_URL=https://auth.example.org/token

# Transport
# MCP transport mode: "http" (default) or "stdio"
# MCP_TRANSPORT=http
PORT=5000
# BIND_HOST=127.0.0.1

# HTTP Security
# Comma-separated hostnames for DNS rebinding protection (required when binding 0.0.0.0)
# ALLOWED_HOSTS=your-app.azurecontainerapps.io

# Debugging
# Enable verbose FHIR request logging (includes query params — may contain PHI)
# DEBUG=true
